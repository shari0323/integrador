<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      alignment="CENTER" spacing="30"
      style="-fx-background-color: #ecf0f1;">

    <padding>
        <Insets top="60" right="40" bottom="60" left="40"/>
    </padding>

    <Label text="Gestión de Talento Humano"
           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Button text="Servidores Públicos" fx:id="btnServers"
            prefWidth="200" prefHeight="55"
            style="-fx-font-size: 18px; -fx-background-color: #3498db; -fx-text-fill: white;"/>

    <Button text="Gestión de Cargos" fx:id="btnPositions"
            prefWidth="200" prefHeight="55"
            style="-fx-font-size: 18px; -fx-background-color: #3498db; -fx-text-fill: white;"/>

</VBox>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.PositionController"
      spacing="15">

    <padding>
        <Insets top="20" right="25" bottom="20" left="25"/>
    </padding>

    <Label text="Gestión de Cargos"
           style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <GridPane hgap="15" vgap="12">
        <Label text="Nombre"  GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtName" promptText="Nombre del cargo"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Código"  GridPane.rowIndex="0" GridPane.columnIndex="2"/>
        <TextField fx:id="txtCode" promptText="Código"
                   GridPane.rowIndex="0" GridPane.columnIndex="3"/>

        <Label text="Grado"   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtGrade" promptText="Grado"
                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>
    </GridPane>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"    text="ID"      prefWidth="80"/>
            <TableColumn fx:id="colName"  text="Nombre"  prefWidth="250"/>
            <TableColumn fx:id="colCode"  text="Código"  prefWidth="150"/>
            <TableColumn fx:id="colGrade" text="Grado"   prefWidth="150"/>
        </columns>
    </TableView>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <padding>
            <Insets top="10"/>
        </padding>
        <Button text="Guardar"
                onAction="#save"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                       -fx-pref-width: 130; -fx-font-size: 14px;"/>
        <Button text="Eliminar"
                onAction="#delete"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-pref-width: 130; -fx-font-size: 14px;"/>
    </HBox>

</VBox>
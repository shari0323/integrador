<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.DependenciesController"
            prefWidth="1300"
            prefHeight="800"
            style="-fx-background-color: #f4f7fb;">

    <top>

        <VBox spacing="8"
              style="-fx-background-color: white;
                     -fx-padding: 20;
                     -fx-border-color: #dfe6ee;
                     -fx-border-width: 0 0 1 0;">

            <Label text="Dashboard General"
                   style="-fx-font-size: 30px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #2c3e50;"/>

            <Label text="Resumen general del sistema de Talento Humano"
                   style="-fx-font-size: 14px;
                          -fx-text-fill: #7f8c8d;"/>

        </VBox>

    </top>

    <center>

        <VBox spacing="22"
              padding="25">

            <!-- CARDS -->

            <HBox spacing="20">

                <VBox spacing="8"
                      prefWidth="250"
                      style="-fx-background-color: #3498db;
                             -fx-background-radius: 15;
                             -fx-padding: 20;">

                    <Label text="👥 Total Servidores"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 16px;
                                  -fx-font-weight: bold;"/>

                    <Label fx:id="lblTotalServers"
                           text="0"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 34px;
                                  -fx-font-weight: bold;"/>

                </VBox>

                <VBox spacing="8"
                      prefWidth="250"
                      style="-fx-background-color: #2ecc71;
                             -fx-background-radius: 15;
                             -fx-padding: 20;">

                    <Label text="💼 Total Cargos"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 16px;
                                  -fx-font-weight: bold;"/>

                    <Label fx:id="lblTotalPositions"
                           text="0"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 34px;
                                  -fx-font-weight: bold;"/>

                </VBox>

                <VBox spacing="8"
                      prefWidth="250"
                      style="-fx-background-color: #9b59b6;
                             -fx-background-radius: 15;
                             -fx-padding: 20;">

                    <Label text="🏢 Dependencias"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 16px;
                                  -fx-font-weight: bold;"/>

                    <Label fx:id="lblTotalDependencies"
                           text="0"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 34px;
                                  -fx-font-weight: bold;"/>

                </VBox>

                <VBox spacing="8"
                      prefWidth="250"
                      style="-fx-background-color: #e67e22;
                             -fx-background-radius: 15;
                             -fx-padding: 20;">

                    <Label text="🏖 Vacaciones"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 16px;
                                  -fx-font-weight: bold;"/>

                    <Label fx:id="lblTotalVacations"
                           text="0"
                           style="-fx-text-fill: white;
                                  -fx-font-size: 34px;
                                  -fx-font-weight: bold;"/>

                </VBox>

            </HBox>

            <!-- CHART + TABLE -->

            <HBox spacing="20"
                  VBox.vgrow="ALWAYS">

                <!-- PIE CHART -->

                <VBox spacing="15"
                      prefWidth="420"
                      style="-fx-background-color: white;
                             -fx-background-radius: 15;
                             -fx-padding: 20;
                             -fx-border-color: #dfe6ee;
                             -fx-border-radius: 15;">

                    <Label text="Distribución por Dependencias"
                           style="-fx-font-size: 18px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #2c3e50;"/>

                    <PieChart fx:id="chartDependencies"
                              prefHeight="420"/>

                </VBox>

                <!-- TABLE -->

                <VBox spacing="15"
                      HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-background-radius: 15;
                             -fx-padding: 20;
                             -fx-border-color: #dfe6ee;
                             -fx-border-radius: 15;">

                    <Label text="Últimos Servidores Registrados"
                           style="-fx-font-size: 18px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #2c3e50;"/>

                    <TableView fx:id="tableRecent"
                               VBox.vgrow="ALWAYS">

                        <columns>

                            <TableColumn fx:id="colId"
                                         text="ID"
                                         prefWidth="80"/>

                            <TableColumn fx:id="colName"
                                         text="Nombre"
                                         prefWidth="250"/>

                            <TableColumn fx:id="colPosition"
                                         text="Cargo"
                                         prefWidth="220"/>

                        </columns>

                    </TableView>

                </VBox>

            </HBox>

        </VBox>

    </center>

</BorderPane>